<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewfit=cover">
<title>Lagom Terrace — Restaurant & Bar | Belize | Full Menu</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background: linear-gradient(135deg, #0a4a46 0%, #06322f 100%);
    color: #fef7e8;
    font-family: 'Jost', sans-serif;
    overflow-x: hidden;
  }

  :root {
    --teal-deep: #0a4743;
    --teal-mid: #0f5f5a;
    --teal-bright: #1f8a82;
    --gold: #dbb859;
    --gold-light: #eedc9a;
    --cream: #fff7ec;
    --text-muted: #bfddd9;
    --card-bg: rgba(10, 71, 67, 0.75);
    --card-border: rgba(219, 184, 89, 0.28);
    --radius: 18px;
    --alert-yellow: #f7e05e;
    --alert-bg: rgba(247, 224, 94, 0.15);
  }

  .menu-card {
    background: rgba(10, 71, 67, 0.85);
    backdrop-filter: blur(2px);
    border: 1px solid rgba(219, 184, 89, 0.35);
    border-radius: var(--radius);
    padding: 14px 18px;
    transition: all 0.25s ease;
  }
  .menu-card:hover {
    background: rgba(31, 138, 130, 0.9);
    border-color: var(--gold);
    transform: translateY(-2px);
  }

  .menu-item-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: 1px dashed rgba(219, 184, 89, 0.2);
  }
  .menu-item-name {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--cream);
  }
  .menu-item-price {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--gold);
    white-space: nowrap;
    margin-left: 16px;
  }
  .menu-sub-item {
    padding-left: 18px;
    font-size: 0.8rem;
    color: var(--text-muted);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px dashed rgba(219, 184, 89, 0.1);
    padding-bottom: 6px;
    margin-bottom: 2px;
  }
  .item-description {
    font-size: 0.7rem;
    color: var(--text-muted);
    padding-left: 0;
    margin-top: -4px;
    margin-bottom: 6px;
    font-style: italic;
    line-height: 1.3;
  }
  .featured-badge {
    background: var(--gold);
    color: #0a3c38;
    font-size: 0.6rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
    margin-left: 8px;
    vertical-align: middle;
    text-transform: uppercase;
  }
  .flavor-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 10px;
    padding-top: 6px;
  }
  .flavor-pill {
    background: rgba(219, 184, 89, 0.12);
    border: 1px solid rgba(219, 184, 89, 0.4);
    border-radius: 20px;
    padding: 4px 12px;
    font-size: 0.7rem;
    color: var(--gold-light);
  }
  .beer-table {
    width: 100%;
    border-collapse: collapse;
  }
  .beer-table th, .beer-table td {
    padding: 10px 12px;
    text-align: left;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .beer-table th {
    color: var(--gold);
    font-weight: 500;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
  }
  .beer-table td.price {
    color: var(--gold);
    font-weight: 500;
  }
  .craft-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 12px 0;
  }
  .craft-pill {
    background: rgba(15, 95, 90, 0.8);
    border: 1px solid rgba(219, 184, 89, 0.3);
    border-radius: 40px;
    padding: 6px 16px;
    font-size: 0.8rem;
  }
  .seasonal-badge {
    background: rgba(219,184,89,0.2);
    font-size: 0.65rem;
    padding: 2px 8px;
    border-radius: 12px;
    margin-left: 8px;
  }
  
  .section-image-banner {
    width: 100%;
    height: auto;
    border-radius: 20px;
    margin-bottom: 25px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    border: 1px solid rgba(219, 184, 89, 0.3);
    transition: transform 0.3s ease;
    display: block;
  }
  .section-image-banner:hover {
    transform: scale(1.01);
  }
  
  .hero-logo {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
  }
  .hero-logo-img {
    max-width: 200px;
    height: auto;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.3));
  }
  
  .hero {
    background: radial-gradient(circle at 30% 20%, #0d5f5a, #06322f);
    padding: 40px 24px 40px;
    text-align: center;
  }
  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.8rem, 8vw, 4.8rem);
    font-weight: 600;
    color: var(--cream);
    letter-spacing: -0.02em;
  }
  .hero-desc {
    color: #bfddd9;
    max-width: 500px;
    margin: 12px auto 0;
    font-size: 1rem;
    font-weight: 300;
  }
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
    margin-top: 20px;
    font-size: 0.85rem;
  }
  .hero-meta span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  
  /* ===== IMPROVED STICKY ALLERGY NOTICE - FULLY VISIBLE ===== */
  .allergy-notice-sticky {
    position: sticky;
    top: 58px; /* sits directly below sticky nav */
    z-index: 99;
    background: rgba(6, 50, 47, 0.98);
    backdrop-filter: blur(12px);
    border-bottom: 2px solid var(--alert-yellow);
    border-top: 1px solid rgba(247, 224, 94, 0.4);
    padding: 14px 20px;
    text-align: center;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--alert-yellow);
    letter-spacing: 0.3px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.3);
    width: 100%;
  }
  .allergy-notice-sticky span {
    background: rgba(247, 224, 94, 0.1);
    display: inline-block;
    padding: 6px 28px;
    border-radius: 60px;
    border-left: 3px solid var(--alert-yellow);
    border-right: 1px solid rgba(247, 224, 94, 0.5);
    font-weight: 500;
    backdrop-filter: blur(4px);
    max-width: 90%;
    line-height: 1.4;
  }
  
  .sticky-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(7, 55, 51, 0.97);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(219, 184, 89, 0.3);
    padding: 10px 12px;
  }
  .nav-tabs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .nav-tab {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(219,184,89,0.25);
    color: #e0f0ed;
    padding: 6px 16px;
    border-radius: 40px;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .nav-tab:hover {
    background: rgba(219,184,89,0.2);
    border-color: var(--gold);
  }
  .nav-tab.active {
    background: var(--gold);
    color: #0a3c38;
    border-color: var(--gold);
  }
  .main {
    max-width: 1000px;
    margin: 0 auto;
    padding: 40px 20px 80px;
  }
  .menu-section {
    margin-bottom: 55px;
    scroll-margin-top: 135px; /* accounts for double sticky bar (nav + allergy) */
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    border-left: 4px solid var(--gold);
    padding-left: 18px;
    margin-bottom: 22px;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 600;
  }
  .section-icon {
    font-size: 1.8rem;
  }
  .section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(219,184,89,0.4), transparent);
  }
  .two-col-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px 24px;
  }
  .subsection-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--gold);
    margin: 22px 0 12px 0;
    letter-spacing: 0.5px;
    border-left: 2px solid var(--gold);
    padding-left: 12px;
  }
  .subsection-title:first-of-type {
    margin-top: 8px;
  }
  footer {
    text-align: center;
    padding: 30px 20px;
    border-top: 1px solid rgba(219,184,89,0.2);
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  footer strong {
    color: var(--gold);
    font-weight: 500;
  }
  @media (max-width: 700px) {
    .two-col-grid { grid-template-columns: 1fr; }
    .nav-tab { padding: 5px 12px; font-size: 0.65rem; }
    .section-title { font-size: 1.5rem; }
    .hero h1 { font-size: 2rem; }
    .hero-meta { gap: 14px; font-size: 0.75rem; }
    .hero-logo-img { max-width: 140px; }
    .menu-section { scroll-margin-top: 150px; }
    .allergy-notice-sticky { top: 48px; padding: 10px 12px; }
    .allergy-notice-sticky span { padding: 5px 12px; font-size: 0.7rem; }
  }
</style>
</head>
