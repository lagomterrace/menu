<script>
  const navBtns = document.querySelectorAll('.nav-tab');
  const sections = document.querySelectorAll('.menu-section');
  const navBar = document.querySelector('.sticky-nav');
  const allergyBar = document.querySelector('.allergy-notice-sticky');
  
  function scrollToSection(id) {
    const el = document.getElementById(id);
    if (el) {
      let offset = navBar.offsetHeight + (allergyBar ? allergyBar.offsetHeight : 0) + 18;
      window.scrollTo({ top: el.offsetTop - offset, behavior: 'smooth' });
    }
  }
  
  function updateActiveNav() {
    let currentId = '';
    const offsetAdjust = navBar.offsetHeight + (allergyBar ? allergyBar.offsetHeight : 0) + 60;
    const scrollPos = window.scrollY + offsetAdjust;
    sections.forEach(section => {
      const top = section.offsetTop;
      const bottom = top + section.offsetHeight;
      if (scrollPos >= top && scrollPos < bottom) currentId = section.id;
    });
    navBtns.forEach(btn => {
      btn.classList.toggle('active', btn.dataset.target === currentId);
    });
  }
  
  navBtns.forEach(btn => btn.addEventListener('click', () => scrollToSection(btn.dataset.target)));
  window.addEventListener('scroll', updateActiveNav);
  window.addEventListener('load', updateActiveNav);
</script>
